---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const articulos = (await getCollection('articulos')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const title = 'Artículos sobre IA para ganar dinero | IAparaGanar';
const description = 'Todos los artículos sobre cómo ganar dinero online con inteligencia artificial: herramientas, métodos y estrategias en español.';
---

<BaseLayout title={title} description={description} keywords={["articulos ia", "ganar dinero ia", "tutoriales ia español"]}>
  <section class="container-wide py-12">
    <h1 class="text-4xl font-extrabold text-slate-900">Todos los artículos</h1>
    <p class="mt-3 max-w-2xl text-slate-600">Guías prácticas para monetizar la inteligencia artificial. Sin humo.</p>

    <AdSlot slot="6666666666" />

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articulos.map((a) => (
        <ArticleCard
          href={`/articulos/${a.slug}`}
          title={a.data.title}
          description={a.data.description}
          category={a.data.category}
          date={a.data.pubDate}
        />
      ))}
    </div>
  </section>
</BaseLayout>
