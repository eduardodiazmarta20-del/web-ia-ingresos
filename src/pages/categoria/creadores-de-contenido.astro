---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const articulos = (await getCollection('articulos'))
  .filter((a) => ['Creadores de contenido', 'Guías'].includes(a.data.category))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const title = 'IA para creadores de contenido en 2026 | IAparaGanar';
const description = 'Las mejores IAs para creadores de contenido: blog, YouTube, redes sociales y newsletters. Herramientas, flujos y estrategias probadas.';
---

<BaseLayout title={title} description={description} keywords={["ia creadores contenido", "ia youtubers", "ia bloggers", "ia redes sociales"]}>
  <section class="container-wide py-12">
    <span class="tag">Categoría</span>
    <h1 class="mt-3 text-4xl font-extrabold text-slate-900">IA para creadores de contenido</h1>
    <p class="mt-3 max-w-2xl text-slate-600">Si creas contenido digital —blog, vídeo, redes o podcast—, estas herramientas y guías están pensadas para ti.</p>

    <AdSlot slot="8888888888" />

    <h2 class="mt-12 text-2xl font-bold text-slate-900">Stack recomendado</h2>
    <div class="mt-6 space-y-5">
      <AffiliateCard name="Claude Pro" description="Textos largos, newsletters y ebooks con tono humano." price="20 $/mes" rating={9.2} bestFor="Escritura SEO" url="https://claude.ai/" badge="Top contenido" />
      <AffiliateCard name="Midjourney" description="Imágenes y miniaturas de alto impacto visual." price="Desde 10 $/mes" rating={9.2} bestFor="YouTube, Etsy" url="https://www.midjourney.com/" />
      <AffiliateCard name="ElevenLabs" description="Voces hiperrealistas para vídeo, podcast y audiolibros." price="Desde 5 $/mes" rating={9.0} bestFor="YouTube y audio" url="https://elevenlabs.io/" />
    </div>

    <h2 class="mt-12 text-2xl font-bold text-slate-900">Artículos de esta categoría</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articulos.map((a) => (
        <ArticleCard href={`/articulos/${a.slug}`} title={a.data.title} description={a.data.description} category={a.data.category} date={a.data.pubDate} />
      ))}
    </div>
  </section>
</BaseLayout>
