---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import AffiliateCard from '../../components/AffiliateCard.astro';
import AdSlot from '../../components/AdSlot.astro';
import { getCollection } from 'astro:content';

const articulos = (await getCollection('articulos'))
  .filter((a) => ['Emprendedores', 'Automatización', 'Guías'].includes(a.data.category))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const title = 'IA para emprendedores en 2026 | IAparaGanar';
const description = 'Las IAs que todo emprendedor debería usar para validar, lanzar y escalar un negocio en 2026. Herramientas, plan de 30 días y automatizaciones.';
---

<BaseLayout title={title} description={description} keywords={["ia para emprendedores", "inteligencia artificial negocios", "startups ia"]}>
  <section class="container-wide py-12">
    <span class="tag">Categoría</span>
    <h1 class="mt-3 text-4xl font-extrabold text-slate-900">IA para emprendedores</h1>
    <p class="mt-3 max-w-2xl text-slate-600">Lanza más rápido. Valida con menos dinero. Escala sin contratar. La IA es el mayor apalancamiento de esta década.</p>

    <AdSlot slot="1010101010" />

    <h2 class="mt-12 text-2xl font-bold text-slate-900">Stack recomendado</h2>
    <div class="mt-6 space-y-5">
      <AffiliateCard name="ChatGPT Plus" description="Estrategia, investigación, copy, MVPs y productividad general." price="20 $/mes" rating={9.4} bestFor="Founders solopreneurs" url="https://chat.openai.com/" badge="Core" />
      <AffiliateCard name="Make" description="Automatiza cualquier proceso sin código y con IA integrada." price="Desde 10 $/mes" rating={9.0} bestFor="Operaciones y ventas" url="https://www.make.com/" />
      <AffiliateCard name="Perplexity Pro" description="Investigación con fuentes reales. Elimina horas de research." price="20 $/mes" rating={9.0} bestFor="Validación y análisis" url="https://www.perplexity.ai/" />
    </div>

    <h2 class="mt-12 text-2xl font-bold text-slate-900">Artículos de la categoría</h2>
    <div class="mt-6 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {articulos.map((a) => (
        <ArticleCard href={`/articulos/${a.slug}`} title={a.data.title} description={a.data.description} category={a.data.category} date={a.data.pubDate} />
      ))}
    </div>
  </section>
</BaseLayout>
