    <script is:inline define:vars={{ profilePayload, defaultProfileKey }}>
      const profileData = JSON.parse(profilePayload);
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const progressBar = document.getElementById('scroll-progress');
      const updateProgress = () => {
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const progress = maxScroll > 0 ? (window.scrollY / maxScroll) * 100 : 0;
        if (progressBar) progressBar.style.width = `${Math.min(100, Math.max(0, progress))}%`;
      };
      updateProgress();
      window.addEventListener('scroll', updateProgress, { passive: true });

      const revealElements = document.querySelectorAll('.reveal');
      if (!prefersReducedMotion && 'IntersectionObserver' in window) {
        const revealObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.16, rootMargin: '0px 0px -8% 0px' }
        );
        revealElements.forEach((element) => revealObserver.observe(element));
      } else {
        revealElements.forEach((element) => element.classList.add('is-visible'));
      }

      const counters = document.querySelectorAll('[data-counter]');
      if (!prefersReducedMotion && 'IntersectionObserver' in window) {
        const counterObserver = new IntersectionObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const target = Number(entry.target.getAttribute('data-target') || '0');
              const duration = 1400;
              const start = performance.now();
              const animate = (now) => {
                const progress = Math.min((now - start) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                entry.target.textContent = Math.round(target * eased).toString();
                if (progress < 1) {
                  requestAnimationFrame(animate);
                }
              };
              requestAnimationFrame(animate);
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.5 }
        );
        counters.forEach((counter) => counterObserver.observe(counter));
      } else {
        counters.forEach((counter) => {
          counter.textContent = counter.getAttribute('data-target') || '0';
        });
      }

      const profileButtons = document.querySelectorAll('[data-profile-button]');
      const profileResult = document.getElementById('profile-result');
      const profileLabel = document.getElementById('profile-label');
      const profileBadge = document.getElementById('profile-badge');
      const profileModel = document.getElementById('profile-model');
      const profileStack = document.getElementById('profile-stack');
      const profileMonetization = document.getElementById('profile-monetization');
      const profileFirstMove = document.getElementById('profile-first-move');
      const profileWhy = document.getElementById('profile-why');
      const profileRisk = document.getElementById('profile-risk');
      const profileBullets = document.getElementById('profile-bullets');

      const renderProfile = (key) => {
        const profile = profileData[key] || profileData[defaultProfileKey];
        if (!profile) return;

        if (profileResult && !prefersReducedMotion) {
          profileResult.classList.add('is-refreshing');
        }

        window.setTimeout(() => {
          if (profileLabel) profileLabel.textContent = profile.label;
          if (profileBadge) profileBadge.textContent = profile.badge;
          if (profileModel) profileModel.textContent = profile.model;
          if (profileStack) profileStack.textContent = profile.stack;
          if (profileMonetization) profileMonetization.textContent = profile.monetization;
          if (profileFirstMove) profileFirstMove.textContent = profile.firstMove;
          if (profileWhy) profileWhy.textContent = profile.why;
          if (profileRisk) profileRisk.textContent = profile.risk;
          if (profileBullets) {
            profileBullets.innerHTML = profile.bullets
              .map(
                (bullet) =>
                  `<li class="flex gap-3"><span class="mt-2 h-2 w-2 rounded-full bg-gradient-to-br from-amber-300 to-emerald-300"></span><span>${bullet}</span></li>`
              )
              .join('');
          }

          profileButtons.forEach((button) => {
            button.classList.toggle('is-active', button.getAttribute('data-profile-key') === key);
          });

          if (profileResult) {
            profileResult.classList.remove('is-refreshing');
          }
        }, prefersReducedMotion ? 0 : 120);
      };

      profileButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const key = button.getAttribute('data-profile-key');
          renderProfile(key);
        });
      });
      renderProfile(defaultProfileKey);

      const faqItems = document.querySelectorAll('.faq-item');
      faqItems.forEach((item) => {
        item.addEventListener('toggle', () => {
          if (!item.open) return;
          faqItems.forEach((other) => {
            if (other !== item) other.open = false;
          });
        });
      });
    </script>
  </body>
</html>
