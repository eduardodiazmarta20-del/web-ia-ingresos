      }

      .hero-shell::after {
        content: '';
        position: absolute;
        inset: auto 2.5rem 0 2.5rem;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(215, 187, 131, 0.34), transparent);
        pointer-events: none;
      }

      .hero-interface {
        position: relative;
        overflow: hidden;
      }

      .hero-interface::before {
        content: '';
        position: absolute;
        inset: 1.1rem;
        border-radius: 1.4rem;
        border: 1px solid rgba(255, 255, 255, 0.03);
        pointer-events: none;
      }

      .hero-interface::after {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(132, 185, 245, 0.45), transparent);
        pointer-events: none;
      }

      .hero-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(70px);
        opacity: 0.24;
        pointer-events: none;
      }

      .nav-link {
        position: relative;
        color: #b5c3d8;
        transition: color 0.22s ease;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        left: 0.8rem;
        right: 0.8rem;
        bottom: 0.3rem;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(215, 187, 131, 0.6), transparent);
        transform: scaleX(0);
        transform-origin: center;
        transition: transform 0.22s ease;
      }

      .nav-link:hover {
        color: #ffffff;
      }

      .nav-link:hover::after {
        transform: scaleX(1);
      }

      .primary-cta {
        position: relative;
        overflow: hidden;
        background: linear-gradient(135deg, #f8f4ea 0%, #d7bb83 100%);
        color: #0a111d;
        box-shadow: 0 24px 65px rgba(215, 187, 131, 0.2);
      }

      .primary-cta::before {
        content: '';
        position: absolute;
        inset: 1px;
        border-radius: inherit;
        border: 1px solid rgba(255, 255, 255, 0.28);
        pointer-events: none;
      }

      .primary-cta::after {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.28), transparent);
        transform: translateX(-120%);
        transition: transform 0.6s ease;
      }

      .primary-cta:hover::after {
        transform: translateX(120%);
      }

      .secondary-cta {
        border: 1px solid rgba(180, 198, 220, 0.14);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
      }

      .secondary-cta:hover {
        border-color: rgba(215, 187, 131, 0.2);
        background: rgba(255, 255, 255, 0.07);
      }

      .hero-note {
        border: 1px solid rgba(255, 255, 255, 0.08);
        background: rgba(255, 255, 255, 0.04);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
      }

      .section-title {
        font-family: 'Space Grotesk', ui-sans-serif, system-ui, sans-serif;
        font-weight: 700;
        letter-spacing: -0.045em;
        color: var(--text);
      }

      .section-copy {
        color: #b4c2d4;
        line-height: 1.95;
      }

      .text-gradient {
        background: linear-gradient(135deg, #ffffff 14%, #e7ddc8 46%, #a8d8c2 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .signal-gradient {
        background: linear-gradient(135deg, #f8f6f1 0%, #d7bb83 55%, #8fd8b7 100%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .reveal {
        opacity: 0;
        transform: translateY(38px) scale(0.988);
        transition:
          opacity 0.75s ease,
          transform 0.75s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      .profile-pill {
        transition:
          transform 0.28s cubic-bezier(0.22, 1, 0.36, 1),
          border-color 0.28s ease,
          background-color 0.28s ease,
          box-shadow 0.28s ease;
      }

      .profile-pill:hover {
        transform: translateY(-2px);
        border-color: rgba(197, 215, 235, 0.18);
      }

      .profile-pill.is-active {
        border-color: rgba(215, 187, 131, 0.28);
        background: linear-gradient(180deg, rgba(215, 187, 131, 0.09), rgba(145, 222, 184, 0.06));
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.25), inset 0 1px 0 rgba(255, 255, 255, 0.05);
        transform: translateY(-3px);
      }

      .profile-result {
        transition:
          border-color 0.28s ease,
          box-shadow 0.28s ease,
          transform 0.28s ease,
          opacity 0.28s ease;
      }

      .profile-result.is-refreshing {
        opacity: 0.82;
        transform: translateY(4px);
      }

      .faq-item[open] {
        border-color: rgba(215, 187, 131, 0.18);
        background: linear-gradient(180deg, rgba(17, 24, 39, 0.94), rgba(10, 15, 25, 0.84));
      }

      .faq-item summary::-webkit-details-marker {
        display: none;
      }

      .faq-item summary {
        list-style: none;
      }

      .faq-icon {
        transition: transform 0.25s ease, border-color 0.25s ease, background-color 0.25s ease;
      }

      .faq-item[open] .faq-icon {
        transform: rotate(45deg);
        border-color: rgba(215, 187, 131, 0.2);
        background: rgba(215, 187, 131, 0.08);
      }

      .metric-bar > span {
        display: block;
        height: 100%;
        border-radius: inherit;
        background: linear-gradient(90deg, rgba(132, 185, 245, 0.92), rgba(145, 222, 184, 0.86), rgba(215, 187, 131, 0.88));
        box-shadow: 0 0 18px rgba(132, 185, 245, 0.22);
      }

      .mini-grid {
        display: grid;
        gap: 0.8rem;
      }

      .mini-grid > div {
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 1rem;
        background: rgba(255, 255, 255, 0.03);
        padding: 0.95rem;
      }

      .anchor-offset {
        scroll-margin-top: 6rem;
      }

      .scroll-cue {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        color: var(--muted);
      }

      .scroll-cue::before {
        content: '';
        width: 2.8rem;
        height: 1px;
        background: linear-gradient(90deg, rgba(215, 187, 131, 0.5), transparent);
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }

        .reveal,
        .reveal.is-visible,
        .profile-pill,
        .faq-icon,
        .primary-cta::after,
        .profile-result {
          animation: none !important;
          transition: none !important;
          transform: none !important;
          opacity: 1 !important;
        }
      }
    </style>
  </head>
