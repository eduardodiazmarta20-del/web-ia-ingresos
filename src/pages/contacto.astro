---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Contacto | IAparaGanar';
const description = 'Contacta con el equipo de IAparaGanar. Resolvemos dudas, atendemos colaboraciones y escuchamos sugerencias.';
---

<BaseLayout title={title} description={description}>
  <section class="container-prose py-12">
    <h1 class="text-4xl font-extrabold text-slate-900">Contacto</h1>
    <p class="mt-3 text-slate-600">Escríbenos para cualquier duda, colaboración o propuesta. Respondemos en menos de 48 h laborables.</p>

    <form class="mt-8 space-y-4" action="https://formsubmit.co/contacto@iaparaganar.com" method="POST">
      <input type="hidden" name="_subject" value="Nuevo mensaje desde iaparaganar.com" />
      <input type="hidden" name="_captcha" value="true" />

      <div>
        <label for="name" class="block text-sm font-medium text-slate-700">Nombre</label>
        <input id="name" name="name" type="text" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500" />
      </div>
      <div>
        <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
        <input id="email" name="email" type="email" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500" />
      </div>
      <div>
        <label for="message" class="block text-sm font-medium text-slate-700">Mensaje</label>
        <textarea id="message" name="message" rows="6" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-3 focus:border-brand-500 focus:outline-none focus:ring-2 focus:ring-brand-500"></textarea>
      </div>
      <div class="flex items-start gap-2 text-sm text-slate-600">
        <input id="privacy" type="checkbox" required class="mt-1" />
        <label for="privacy">He leído y acepto la <a href="/politica-privacidad" class="text-brand-700 underline">política de privacidad</a>.</label>
      </div>
      <button type="submit" class="btn-primary">Enviar mensaje</button>
    </form>

    <p class="mt-10 text-sm text-slate-500">También puedes escribirnos directamente a <a class="text-brand-700" href="mailto:contacto@iaparaganar.com">contacto@iaparaganar.com</a>.</p>
  </section>
</BaseLayout>
