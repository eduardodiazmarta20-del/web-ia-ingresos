---
interface Props {
  name: string;
  description: string;
  price?: string;
  rating?: number;
  bestFor?: string;
  url: string;
  badge?: string;
}
const { name, description, price = 'Desde 0 €', rating = 9, bestFor, url, badge } = Astro.props;
---

<article class="card relative flex flex-col gap-3 md:flex-row md:items-center md:gap-6">
  {badge && (
    <span class="absolute -top-3 left-4 rounded-full bg-accent-500 px-3 py-1 text-xs font-bold text-slate-900 shadow">
      {badge}
    </span>
  )}
  <div class="flex-1">
    <div class="flex items-center gap-3">
      <h3 class="text-xl font-bold text-slate-900">{name}</h3>
      <span class="inline-flex items-center gap-1 rounded-full bg-amber-100 px-2 py-0.5 text-xs font-semibold text-amber-800">
        ★ {rating}/10
      </span>
    </div>
    <p class="mt-2 text-slate-700">{description}</p>
    {bestFor && <p class="mt-2 text-sm text-slate-500"><strong>Ideal para:</strong> {bestFor}</p>}
    <p class="mt-1 text-sm text-slate-500"><strong>Precio:</strong> {price}</p>
  </div>
  <div class="shrink-0">
    <a href={url} target="_blank" rel="sponsored noopener nofollow" class="btn-affiliate w-full md:w-auto">
      Probar {name} →
    </a>
    <p class="mt-2 text-center text-[11px] text-slate-400">Enlace de afiliado</p>
  </div>
</article>
