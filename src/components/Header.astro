---
const nav = [
  { href: '/mejores-ia-ganar-dinero-2026', label: 'Mejores IA 2026' },
  { href: '/articulos', label: 'Artículos' },
  { href: '/comparativas', label: 'Comparativas' },
  { href: '/reviews', label: 'Reviews' },
  { href: '/categoria/creadores-de-contenido', label: 'Creadores' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="container-wide flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-extrabold text-slate-900" aria-label="IAparaGanar inicio">
      <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-brand-600 to-brand-900 text-white">IA€</span>
      <span class="text-lg">IAparaGanar</span>
    </a>

    <nav aria-label="Principal" class="hidden items-center gap-1 md:flex">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 hover:text-slate-900',
            currentPath.startsWith(item.href) && 'bg-slate-100 text-slate-900',
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href="/mejores-ia-ganar-dinero-2026" class="hidden rounded-xl bg-accent-500 px-4 py-2 text-sm font-semibold text-slate-900 transition hover:bg-accent-400 md:inline-flex">
        Empieza a ganar →
      </a>
      <button id="menu-toggle" aria-label="Abrir menú" class="inline-flex items-center justify-center rounded-lg p-2 text-slate-700 hover:bg-slate-100 md:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-slate-200 bg-white md:hidden">
    <nav class="container-wide flex flex-col py-2" aria-label="Móvil">
      {nav.map((item) => (
        <a href={item.href} class="rounded-lg px-3 py-2 text-slate-700 hover:bg-slate-100">{item.label}</a>
      ))}
      <a href="/mejores-ia-ganar-dinero-2026" class="mt-2 rounded-xl bg-accent-500 px-4 py-2 text-center font-semibold text-slate-900">Empieza a ganar →</a>
    </nav>
  </div>
</header>

<script is:inline>
  const t = document.getElementById('menu-toggle');
  const m = document.getElementById('mobile-nav');
  if (t && m) t.addEventListener('click', () => m.classList.toggle('hidden'));
</script>
